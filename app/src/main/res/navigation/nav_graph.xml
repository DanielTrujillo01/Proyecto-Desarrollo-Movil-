<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.fragmentspractice.fragments.HomeFragment"
        android:label="HomeFragment"
        tools:layout="@layout/home_fragment"
        >
        <action
            android:id="@+id/action_homeFragment_to_ratingFragment"
            app:destination="@id/ratingFragment" />
        <action
            android:id="@+id/action_homeFragment_to_instructionsFragment"
            app:destination="@id/instructionsFragment" />
        <action
            android:id="@+id/action_homeFragment_to_challengeManagementFragment"
            app:destination="@id/ChallengeManagementFragment" />
        <action
            android:id="@+id/action_homeFragment_to_shareFragment"
            app:destination="@id/ShareFragment" />
    </fragment>

    <fragment
        android:id="@+id/ShareFragment"
        android:name="com.example.fragmentspractice.fragments.ShareFragment"
        android:label="ShareFragment"
        tools:layout="@layout/share_fragment"
        />


    <fragment
        android:id="@+id/ChallengeManagementFragment"
        android:name="com.example.fragmentspractice.fragments.ChallengeManagementFragment"
        android:label="ChallengeManagementFragment"
        tools:layout="@layout/challenge_management_fragment"
        />

    <fragment
        android:id="@+id/ratingFragment"
        android:name="com.example.fragmentspractice.fragments.RatingFragment"
        android:label="RatingFragment"
        tools:layout="@layout/rating_fragment"
        />

    <fragment
        android:id="@+id/instructionsFragment"
        android:name="com.example.fragmentspractice.fragments.InstructionsFragment"
        android:label="InstructionFragment"
        tools:layout="@layout/instructions_fragment"
        />

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.fragmentspractice.fragments.SplashFragment"
        android:label="SplashFragment"
        tools:layout="@layout/splash_fragment">
        <action
            android:id="@+id/action_splashFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>
</navigation>
<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="16dp">

    <!-- Tarjeta con el reto (Criterio 1 y 3) + botón Cerrar (Criterio 4) -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="45dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/cardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_challenge_result_dialog"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="56dp"
            android:paddingEnd="24dp"
            android:paddingBottom="44dp">

            <TextView
                android:id="@+id/tvChallengeResultText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="Realiza un RecyclerView que liste una api de Pokemones" />

        </LinearLayout>

        <Button
            style="@style/Widget.MaterialComponents.Button"
            android:id="@+id/btnCerrar"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginTop="-30dp"
            android:backgroundTint="@color/orange"
            android:minWidth="150dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:text="@string/close"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

</LinearLayout>

<!-- Círculo con el Pokémon aleatorio (Criterio 2), se dibuja encima de la
 tarjeta y sobresale de su borde superior -->
    <FrameLayout
        android:id="@+id/pokemonCircleContainer"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="top|center_horizontal"
        android:background="@drawable/bg_pokemon_circle">

        <ImageView
            android:id="@+id/ivPokemon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/pokemon_image_desc"
            android:padding="6dp"
            android:scaleType="centerCrop" />

        <ProgressBar
            android:id="@+id/pbPokemonLoading"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/white" />

    </FrameLayout>

</FrameLayout>
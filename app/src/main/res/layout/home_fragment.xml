<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/woodfloor"
        >

        <include
            android:id="@+id/content_toolbar"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            layout="@layout/toolbar"/>

        <ImageView
            android:id="@+id/home_bottle"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:src="@drawable/bottle_in_the_floor"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            >
        </ImageView>

        <TextView
            android:id="@+id/countdown_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF9800"
            android:textSize="80sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/home_bottle"
            app:layout_constraintEnd_toEndOf="@id/home_bottle"
            app:layout_constraintStart_toStartOf="@id/home_bottle"
            app:layout_constraintTop_toTopOf="@id/home_bottle"
            tools:text="3"
            tools:visibility="visible" />

        <ImageButton
            android:id="@+id/home_button"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/boton_de_play"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:contentDescription="@string/Home_Press_Buttom"
            app:layout_constraintTop_toBottomOf="@id/home_bottle"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/tv_press_me"/>

        <TextView
            android:id="@+id/tv_press_me"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Home_Press_Buttom"
            android:textColor="@color/black"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/home_button"
            >
        </TextView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>